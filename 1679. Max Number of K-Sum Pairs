class Solution(object):
    def maxOperations(self, nums, k):
        s = {}
        count = 0
        for i in nums:
            need = k - i
            if need in s and s[need] >0:
                s[need] -=1
                count +=1
            else:
                if i not in s:
                    s[i] = 0
                s[i] += 1
        return count

        
