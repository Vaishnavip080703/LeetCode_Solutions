class Solution(object):
    def findErrorNums(self, nums):
        freq = {}

        for num in nums:
            freq[num] = freq.get(num, 0) + 1

        duplicate = missing = 0

        for i in range(1, len(nums) + 1):
            if i not in freq:
                missing = i
            elif freq[i] == 2:
                duplicate = i

        return [duplicate, missing]

nums = [3, 2, 2]
v = Solution()
print(v.findErrorNums(nums))
