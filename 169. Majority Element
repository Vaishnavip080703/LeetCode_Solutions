class Solution(object):
    def majorityElement(self, nums):
        m = len(nums)
        d = {}
        for i in nums:
            if i not in d:
                d[i] = 1
            else:
                d[i] += 1
        print(d)
        for k,j in d.items():
            if j > m/2:
                return k

