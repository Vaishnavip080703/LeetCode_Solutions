class Solution(object):
    def twoSum(self, numbers, target):
        seen = {}  # dictionary to store number and its index
        
        for i in range(len(numbers)):
            needed = target - numbers[i]
            
            if needed in seen:
                return [seen[needed] + 1, i + 1]  # 1-based index
            
            seen[numbers[i]] = i


# Input
nums = [2, 7, 11, 15]
target = 9

# Create object and call function
v = Solution()
result = v.twoSum(nums, target)

# Output
print(result)
