class Solution(object):
    def shuffle(self, nums, n):
        a = [0]*len(nums)
        j=0
        for i in range(len(nums)//2):
            a[j] = nums[i]
            a[j+1] = nums[n+i]
            j+=2
            #a.append(nums[i])
            #a.append(nums[n+i])
        return a

nums = [2,5,1,3,4,7]
n = 3
v = Solution()
print(v.shuffle(nums,n))
