class Solution(object):
    def fourSum(self, nums, target):
        nums = sorted(nums)
        l = []

        for i in range(len(nums) - 3):
            if i > 0 and nums[i] == nums[i - 1]:
                continue

            for j in range(i + 1, len(nums) - 2):
                if j > i + 1 and nums[j] == nums[j - 1]:
                    continue

                first = nums[i]
                second = nums[j]
                start = j + 1
                end = len(nums) - 1

                while start < end:
                    ans = first + second + nums[start] + nums[end]

                    if ans == target:
                        l.append([first, second, nums[start], nums[end]])

                        start += 1
                        end -= 1

                        while start < end and nums[start] == nums[start - 1]:
                            start += 1

                        while start < end and nums[end] == nums[end + 1]:
                            end -= 1

                    elif ans < target:
                        start += 1

                    else:
                        end -= 1

        return l


nums = [2, 2, 2, 2, 2]
target = 8
v = Solution()
print(v.fourSum(nums, target))
