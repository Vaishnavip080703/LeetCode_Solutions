class Solution(object):
    def searchInsert(self, nums,target):
        count = 0
        for i in range(len(nums)):
            if nums[i] == target:
                index = i
                found = 1
                break
            else:
                found = 0
                if nums[i] > target:
                    break
                count +=1
                
                
        if found:
            return index
        else:
            return count

nums = [1,3,5,6]
target = 2
v = Solution()
print(v.searchInsert(nums,target))
