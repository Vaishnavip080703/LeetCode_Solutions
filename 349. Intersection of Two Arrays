class Solution(object):
    def intersection(self, nums1, nums2):
        l = []
        for i in nums1:
            if i in nums2:
                if i not in l:
                    l.append(i)
                    
        return l
        
                

nums1 = [8,0,3]
nums2 = [0,0]
v = Solution()
print(v.intersection(nums1,nums2))
