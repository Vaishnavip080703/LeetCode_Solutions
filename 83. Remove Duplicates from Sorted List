# Definition for singly-linked list.
class ListNode(object):
     def __init__(self, val=0, next=None):
         self.val = val
         self.next = next
class LinkedList():
    def insert_node(self,head):
        if len(head) == 0:
            return None
        self.head = ListNode(head[0])
        current = self.head
        for i in head[1:]:
            current.next = ListNode(i)
            current =  current.next
        return self.head
