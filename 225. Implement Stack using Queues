class MyStack(object):

    def __init__(self):
        self.operations = ["MyStack", "push", "push", "top", "pop", "empty"]
        self.value = [[], [1], [2], [], [], []]
        self.stack = []

    def push(self, x):
        self.stack.append(x)
        

    def pop(self):
        return self.stack.pop()
        

    def top(self):
        return self.stack[-1] if self.stack else None
        

    def empty(self):
        return len(self.stack) == 0
        


