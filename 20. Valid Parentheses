class Solution(object):
    def isValid(self, s):
        stack = []
        d = {'{': '}', '(': ')', '[': ']'}
        
        for char in s:
            if char in d:
                stack.append(char)
            else:
                if not stack:
                    return False
                top = stack.pop()
                if d[top] != char:
                    return False
        
        return len(stack) == 0

s = "()"
v = Solution()
print(v.isValid(s))
