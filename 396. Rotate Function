#Input: nums = [4,3,2,6]
#Output: 26
class Solution(object):
    def maxRotateFunction(self, nums):
        n = len(nums)
        if n < 1:
            return 0
        total_sum = sum(nums)
        current = 0
        for i in range(n):
            current += i*nums[i]
        #print(current)
        max_val = current
        for k in range(1, n):
            current = current + total_sum - n * nums[n - k]
            max_val = max(max_val, current)
        
        return max_val

nums = [4,3,2,6]
v= Solution()
print(v.maxRotateFunction(nums))
