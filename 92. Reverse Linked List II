class ListNode:
    def __init__(self, val=0):
        self.val = val
        self.next = None

class Solution(object):
    def __init__(self):
        self.head = None
        self.count = 0
    def insert_node(self, n):
        self.head = ListNode(n[0])
        current = self.head
        for i in n[1:]:
            current.next = ListNode(i)
            current = current.next
        return self.head
    def reverseBetween(self, head, left, right):

        dummy = ListNode(0)
        dummy.next = head

        prev = dummy

        # 1. Move prev to node before left
        for _ in range(left - 1):
            prev = prev.next

        # 2. Start reversing from left node
        curr = prev.next

        # 3. Standard reversal inside range
        prev_sub = None

        for _ in range(right - left + 1):
            nxt = curr.next
            curr.next = prev_sub
            prev_sub = curr
            curr = nxt

        # 4. Reconnect
        prev.next.next = curr
        prev.next = prev_sub

        return dummy.next
    
n = [1,2,3,4,5,6]
left = 2
right = 4
v = Solution()
h = v.insert_node(n)
h = v.reverseBetween(h,left,right)
