class Solution(object):
    def twoSum(self, nums, target):
        l = []
        for i in range(len(nums)):
            for j in range(i+1, len(nums)):
                if nums[i] + nums[j] == target:
                    #print(nums[i],nums[j])
                    l.append(i)
                    l.append(j)
                    break
        return l

nums = [3,2,4]
target = 6
v = Solution()
print(v.twoSum(nums, target))
        
