class Solution(object):
    def buildArray(self, target, n):
        l = []
        count = 0
        for i in range(1,n+1):
            if count < len(target):
                if i ==  target[count]:
                    l.append("Push")
                    count +=1
                else:
                    l.append("Push")
                    l.append("Pop")
                
        return l
            
        
target = [1,3]
n = 3
v = Solution()
print(v.buildArray(target,n))
