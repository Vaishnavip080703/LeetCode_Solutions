class Solution(object):
    def search(self, nums,target):
        start = 0
        end = len(nums)-1
        while start<=end:
            if nums[start] == target:
                print(start,end)
                found = 1
                index = start
                break
            if nums[end] == target:
                found =1
                index = end
                break
            else:
                found = 0
                start +=1
