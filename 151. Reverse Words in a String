class Solution(object):
    def reverse(self, s, start, end):
        sub = list(s[start:end+1])
        i, j = 0, len(sub) - 1
        
        while i < j:
            sub[i], sub[j] = sub[j], sub[i]
            i += 1
            j -= 1
        
        return "".join(sub)

    def reverseWords(self, s):
        start = 0
        end = len(s) - 1
        k = ""

        m = self.reverse(s, start, end)

        for i in range(len(m)):
            if m[i] == " ":
                k += self.reverse(m, start, i - 1) + " "
                start = i + 1

        # handle last word
        k += self.reverse(m, start, len(m) - 1)

        return " ".join(s.split()[::-1])


chars = "the sky is blue"
v = Solution()
print(v.reverseWords(chars))
