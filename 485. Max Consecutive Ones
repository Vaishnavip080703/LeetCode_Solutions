class Solution(object):
    def findMaxConsecutiveOnes(self, nums):
        current =  prev = 0
        for i in nums:
            if i ==1:
                current +=1
            else:
                current =0
                
            if prev < current:
                prev = current
                
        return prev
                
        
nums = [1,0,1,1,0,1]
v = Solution()
print(v.findMaxConsecutiveOnes(nums))
