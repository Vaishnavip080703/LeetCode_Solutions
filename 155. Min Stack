class MinStack(object):

    def __init__(self):
        self.stack = []
        self.operations = ["MinStack","push","push","push","getMin","pop","top","getMin"]
        self.values     = [[],[-2],[0],[-3],[],[],[],[]]
        

    def push(self, val):
        self.stack.append(val)
        return self.stack

        

    def pop(self):
        m = self.stack[-1]
        self.stack.pop()
        return self.stack
        

    def top(self):
        return self.stack[-1]
        

    def getMin(self):
        k = min(self.stack)
        return k
  
